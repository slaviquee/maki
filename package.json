{
  "name": "maki",
  "version": "0.1.0",
  "description": "Hardware-signed onchain agent for everyday DeFi with Secure Enclave and Ledger, deterministic execution, and human-backed verification",
  "type": "module",
  "files": [
    "dist",
    "src/skills",
    "signer-daemon/bin",
    "signer-daemon/Sources",
    "signer-daemon/Package.swift",
    "signer-daemon/MakiSigner.entitlements",
    "scripts",
    "docs/first-transaction.md",
    "README.md"
  ],
  "piConfig": {
    "name": "maki",
    "configDir": ".maki"
  },
  "bin": {
    "maki": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@ledgerhq/context-module": "^1.15.0",
    "@ledgerhq/device-management-kit": "^1.2.0",
    "@ledgerhq/device-signer-kit-ethereum": "^1.13.0",
    "@ledgerhq/device-transport-kit-speculos": "^1.2.0",
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "^0.65.0",
    "@sinclair/typebox": "^0.34.0",
    "@worldcoin/agentkit": "^0.1.6",
    "@x402/core": "^2.9.0",
    "@x402/evm": "^2.9.0",
    "@x402/hono": "^2.9.0",
    "better-sqlite3": "^12.0.0",
    "chalk": "^5.4.0",
    "ethers": "^6.16.0",
    "hono": "^4.12.10",
    "permissionless": "^0.3.0",
    "rxjs": "7.8.2",
    "viem": "^2.47.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "pi": {
    "extensions": [
      "./dist/extensions"
    ],
    "skills": [
      "./src/skills"
    ]
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "pi-package",
    "web3",
    "wallet",
    "defi",
    "erc-4337"
  ]
}
